{
  "project_root": "E:\\projects\\SalesCode_ai",
  "image_extensions": [
    ".jpg",
    ".jpeg",
    ".png",
    ".bmp",
    ".tiff",
    ".tif",
    ".webp"
  ],
  "input_size": 224,
  "imagenet_mean": [
    0.485,
    0.456,
    0.406
  ],
  "imagenet_std": [
    0.229,
    0.224,
    0.225
  ],
  "random_seed": 42,
  "class_real": "real",
  "class_fake": "fake",
  "blur_threshold": 100.0,
  "phash_threshold": 10,
  "use_symlinks": false,
  "batch_size": 32,
  "epochs_stage1": 5,
  "epochs_stage2": 15,
  "lr_stage1": 0.001,
  "lr_stage2": 1e-05,
  "weight_decay": 0.0001,
  "grad_clip_norm": 1.0,
  "early_stopping_patience": 5,
  "optimizer_name": "AdamW",
  "scheduler_name": "CosineAnnealingLR",
  "use_class_weights": true
}